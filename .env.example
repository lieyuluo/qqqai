# Server
BOT_QQ=0
BOT_PORT=8080

# LLM
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-flash
LLM_PERSONA=你叫「小雨」，是一个生活在 QQ 群里的虚拟群友。

# Model routing
CHAT_MODEL_TYPE=openai
INTENT_MODEL_TYPE=openai
EMBEDDING_MODEL_TYPE=ark

# Ark
ARK_KEY=
ARK_CHAT_MODEL=doubao-seed-2-0-lite-260428
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215

# DeepSeek
DEEPSEEK_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen
QWEN_KEY=
QWEN_EMBEDDING=text-embedding-v4
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# MySQL. In Docker Compose, docker-compose.yml overrides MYSQL_HOST to mysql.
# For host-side development against the shared server, use 152.136.27.145.
MYSQL_HOST=152.136.27.145
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=qqqai

# Redis. In Docker Compose, docker-compose.yml overrides REDIS_ADDR to redis:6379.
# For host-side development against the shared server, use 152.136.27.145:6379.
REDIS_ADDR=152.136.27.145:6379
REDIS_PASSWORD=
REDIS_DB=0

# NapCat
NAPCAT_HTTP_BASE_URL=http://127.0.0.1:3000
NAPCAT_ACCESS_TOKEN=

# Optional remote file indexer. Leave empty to index files in the main process.
INDEXER_URL=
INDEXER_TIMEOUT_SECONDS=180

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_API_URL=https://api.smith.langchain.com

# Milvus. In Docker Compose, docker-compose.yml overrides MILVUS_ADDR to milvus:19530.
# For host-side development against the shared server, use 152.136.27.145:19530.
MILVUS_ADDR=152.136.27.145:19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=qqqai_documents
MILVUS_TOP_K=5

# Elasticsearch. In Docker Compose, docker-compose.yml overrides this to http://elasticsearch:9200.
ELASTICSEARCH_ADDRESSES=http://152.136.27.145:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=qqqai_documents

# Session
SESSION_MAX_MESSAGES=10

# Memory
MEMORY_DIR=data/memory
MEMORY_SUMMARY_INTERVAL=20
MEMORY_MAX_ENTRIES=20

# WebSocket
WEBSOCKET_ALLOWED_ORIGINS=*
WEBSOCKET_READ_TIMEOUT=300
WEBSOCKET_WRITE_TIMEOUT=10
